# ============================================================
# Banyakob — Environment Configuration
# Copy to .env and fill in all values
# ============================================================

# --- Shopify ---
SHOPIFY_SHOP_NAME=          # your-store.myshopify.com (just the subdomain)
SHOPIFY_API_KEY=            # Shopify app API key
SHOPIFY_API_SECRET=         # Shopify app API secret
SHOPIFY_ACCESS_TOKEN=       # Shopify Admin API access token

# --- Etsy ---
ETSY_API_KEY=               # Etsy v3 API key
ETSY_API_SECRET=            # Etsy v3 API secret
ETSY_ACCESS_TOKEN=          # Etsy OAuth2 access token
ETSY_SHOP_ID=               # Etsy shop numeric ID

# --- CustomCat ---
CUSTOMCAT_API_KEY=          # CustomCat API key
CUSTOMCAT_API_URL=https://api.customcat.com  # CustomCat base URL

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=          # Anthropic API key for listing copy generation

# --- OpenAI ---
OPENAI_API_KEY=             # OpenAI API key (image/alt generation)

# --- Meta Ads ---
META_APP_ID=                # Meta app ID
META_APP_SECRET=            # Meta app secret
META_ACCESS_TOKEN=          # Meta Marketing API access token
META_AD_ACCOUNT_ID=         # Meta ad account ID (act_XXXXXXXXX)
META_PIXEL_ID=              # Meta pixel ID installed on Shopify

# --- Social / Content ---
TIKTOK_ACCESS_TOKEN=        # TikTok API access token (TBD)
INSTAGRAM_ACCESS_TOKEN=     # Instagram Graph API access token (TBD)

# --- Notifications ---
NOTIFICATION_WEBHOOK_URL=   # Webhook URL for error/status notifications (Slack, Discord, etc.)

# --- App ---
NODE_ENV=development        # development | production
LOG_LEVEL=info              # debug | info | warn | error
